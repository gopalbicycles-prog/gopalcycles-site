---
const today = new Date();
---

<footer class="site-footer">
  <div class="footer-inner">
    <div class="footer-brand">
      <a href="/" class="footer-logo">
        <img src="/assets/Gopallogo.png" alt="GopalCycles" width="36" height="36" />
        <span>GopalCycles</span>
      </a>
      <p class="footer-tagline">
        Fleet management software for rental operators.<br />
        GPS tracking, smart locks &amp; GopalDesk.
      </p>
    </div>

    <div class="footer-links">
      <div>
        <h4>Product</h4>
        <a href="/gopaldesk/">GopalDesk</a>
        <a href="/rental-equipment-tracking/">Tracking</a>
        <a href="/blog/">Blog</a>
      </div>
      <div>
        <h4>Company</h4>
        <a href="/about/">About</a>
        <a href="/contact/">Contact</a>
        <a href="/auth/login.html">Login</a>
      </div>
      <div>
        <h4>Integrations</h4>
        <a href="/gopaldesk/#omni">Omni</a>
        <a href="/gopaldesk/#segway">Segway-Ninebot</a>
        <a href="/gopaldesk/#free">Free Rental Software</a>
      </div>
    </div>
  </div>

  <div class="footer-bottom">
    <span>&copy; {today.getFullYear()} GopalCycles. All rights reserved.</span>
    <span class="footer-sub">Built in Toronto, Canada &middot; <a href="mailto:hello@gopalcycles.com">hello@gopalcycles.com</a></span>
  </div>
</footer>

<style>
  .site-footer {
    background: #0f172a;
    color: #94a3b8;
    padding: 60px 0 28px;
  }

  .footer-inner {
    max-width: 1120px;
    margin: 0 auto;
    padding: 0 24px;
    display: grid;
    grid-template-columns: 1.4fr 1.6fr;
    gap: 48px;
  }

  .footer-brand {
    display: flex;
    flex-direction: column;
    gap: 14px;
  }

  .footer-logo {
    display: flex;
    align-items: center;
    gap: 10px;
    text-decoration: none;
    color: #f1f5f9;
    font-size: 18px;
    font-weight: 800;
    letter-spacing: -0.03em;
  }

  .footer-logo img {
    border-radius: 8px;
    background: white;
    padding: 2px;
  }

  .footer-tagline {
    margin: 0;
    font-size: 14px;
    line-height: 1.6;
    color: #64748b;
  }

  .footer-links {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 32px;
  }

  .footer-links h4 {
    color: #f1f5f9;
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin: 0 0 14px;
  }

  .footer-links a {
    display: block;
    color: #64748b;
    text-decoration: none;
    font-size: 14px;
    margin-bottom: 10px;
    transition: color 0.15s;
  }

  .footer-links a:hover {
    color: #e2e8f0;
  }

  .footer-bottom {
    max-width: 1120px;
    margin: 40px auto 0;
    padding: 20px 24px 0;
    border-top: 1px solid #1e293b;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    flex-wrap: wrap;
    gap: 8px;
  }

  .footer-sub a {
    color: #64748b;
    text-decoration: none;
  }

  .footer-sub a:hover {
    color: #94a3b8;
  }

  @media (max-width: 800px) {
    .footer-inner {
      grid-template-columns: 1fr;
      gap: 36px;
    }

    .footer-links {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-bottom {
      flex-direction: column;
      align-items: flex-start;
    }
  }

  @media (max-width: 500px) {
    .footer-links {
      grid-template-columns: 1fr;
    }
  }
</style>
