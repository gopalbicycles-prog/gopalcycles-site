---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="GopalDesk is a free desktop IoT server app for rental operators. Run on your own laptop — Windows, macOS, Linux. Monitor live device connections, inspect TCP messages, and send commands." />
    <title>GopalDesk | Free Desktop IoT Server for Rental Operators</title>
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
  </head>
  <body>
    <Header />
    <main>

      <section class="hero">
        <div class="container">
          <p class="eyebrow">GopalDesk</p>
          <h1>Your laptop as an IoT server. Free, no subscription.</h1>
          <p class="sub">
            GopalDesk is a desktop Electron app that turns your laptop into an IoT server
            for connected rental equipment. Download, create a free account, and start
            connecting devices over TCP — no cloud platform needed.
          </p>
          <div class="actions">
            <a class="button primary" href="/download/">Download GopalDesk</a>
            <a class="button secondary" href="/auth/signup.html">Create Free Account</a>
          </div>
        </div>
      </section>

      <!-- PLATFORMS -->
      <section class="platforms-strip">
        <div class="container">
          <p class="platforms-label">Available for</p>
          <div class="platforms">
            <div class="platform"><span class="platform-icon">🪟</span><strong>Windows</strong><span>Tested on Windows 11</span></div>
            <div class="platform"><span class="platform-icon">🍎</span><strong>macOS ARM64</strong><span>Apple Silicon (M1/M2/M3)</span></div>
            <div class="platform"><span class="platform-icon">🍎</span><strong>macOS Intel</strong><span>Intel-based Macs</span></div>
            <div class="platform"><span class="platform-icon">🐧</span><strong>Linux</strong><span>Ubuntu 22.04 (.deb)</span></div>
          </div>
        </div>
      </section>

      <!-- HOW IT WORKS -->
      <section class="section">
        <div class="container">
          <h2>Get started in three steps</h2>
          <div class="steps-grid">
            <div class="step">
              <div class="step-num">1</div>
              <h3>Download &amp; install</h3>
              <p>Download the installer for your OS from the <a href="/download/">download page</a>. Note: the app is not yet code-signed, so your OS may show an "unknown developer" warning — this is expected. Approve it to proceed.</p>
            </div>
            <div class="step">
              <div class="step-num">2</div>
              <h3>Create a GopalCycles account</h3>
              <p>Sign up at <a href="/auth/signup.html">gopalcycles.com/auth/signup.html</a>. Verify your email. Your account works across GopalDesk and GopalWeb.</p>
            </div>
            <div class="step">
              <div class="step-num">3</div>
              <h3>Connect your device</h3>
              <p>After login, the app shows your server IP and port. Configure your IoT device with that IP and the Generic Port. It will appear in the Live Connections table.</p>
            </div>
          </div>
        </div>
      </section>

      <!-- DASHBOARD OVERVIEW -->
      <section class="section alt">
        <div class="container">
          <h2>What you see after login</h2>
          <p class="section-sub">The main dashboard gives you a live view of all connected devices.</p>
          <div class="grid">
            <article class="card">
              <h3>Live Connections table</h3>
              <p>Lists every connected device with its identifier (IMEI), protocol, online/offline status, connection time, and the most recent message received.</p>
            </article>
            <article class="card">
              <h3>Server IP &amp; Port</h3>
              <p>Your server address is shown at the top — <code>iot.gopalcycles.com</code> — along with the Generic Port for your account. Point your device at these to connect.</p>
            </article>
            <article class="card">
              <h3>Available Device Types</h3>
              <p>Select which device protocols you want active (Generic, Okai Scooter, etc.) and save. Changes take effect on next login.</p>
            </article>
          </div>
        </div>
      </section>

      <!-- CONNECTION INSPECTOR -->
      <section class="section">
        <div class="container two-col">
          <div>
            <p class="eyebrow-sm">Connection Inspector</p>
            <h2>Inspect and control any connected device.</h2>
            <p>
              Click any device row to open the Connection Inspector window. You get a
              live raw message stream — useful for debugging device protocols and
              verifying what data your hardware is sending.
            </p>
            <p>
              The status panel shows connection state, last message, and message counts.
              Quick controls let you lock, unlock, or request GPS coordinates with one click.
            </p>
          </div>
          <div class="panel">
            <h3>Inspector features</h3>
            <ul>
              <li><strong>Raw Stream</strong> — live incoming TCP messages</li>
              <li><strong>Device Status</strong> — connection state, message counts</li>
              <li><strong>Quick Controls</strong> — Lock / Unlock / Get Location</li>
              <li><strong>Send Command</strong> — ASCII or HEX mode</li>
              <li><strong>Save Logs</strong> — export message history</li>
            </ul>
            <div class="code-block">
              <span class="recv-tag">RECV</span>
              <code>*HBCR,NB,860537061919777,Q0,410,80,25,46000,V144P0#</code>
            </div>
            <p class="code-note">Example raw message from a Segway device</p>
          </div>
        </div>
      </section>

      <!-- GOPALWEB OPTION -->
      <section class="section alt">
        <div class="container two-col reverse">
          <div class="panel">
            <h3>GopalWeb protocol support</h3>
            <ul>
              <li>Segway-Ninebot scooters</li>
              <li>Omni IoT devices</li>
              <li>Okai scooters</li>
              <li>Generic TCP (any device)</li>
              <li>More being added continuously</li>
            </ul>
            <a class="panel-link" href="http://webapp.gopalcycles.com/login" target="_blank" rel="noopener">Open GopalWeb →</a>
          </div>
          <div>
            <p class="eyebrow-sm">Don't want to run a local server?</p>
            <h2>Use GopalWeb — our hosted option.</h2>
            <p>
              If running an IoT server on your laptop isn't right for your operation,
              GopalWeb is our hosted server with custom protocol support for Omni,
              Segway, Okai, and more.
            </p>
            <p>
              Same GopalCycles account. No extra setup. Just log in and connect your devices.
            </p>
          </div>
        </div>
      </section>

      <!-- PROTOCOL NOTE -->
      <section class="section">
        <div class="container">
          <div class="protocol-note-box">
            <div>
              <h3>Current protocol support in GopalDesk</h3>
              <p>
                GopalDesk currently supports <strong>Generic TCP</strong> — which works with any device
                that can send TCP data. Specific protocol parsers for Segway, Omni, and Okai are
                under active development. For protocol-specific support today, use
                <a href="http://webapp.gopalcycles.com/login" target="_blank" rel="noopener">GopalWeb</a>.
              </p>
            </div>
            <a class="button primary" href="/contact/">Ask about your device</a>
          </div>
        </div>
      </section>

      <section class="cta-section">
        <div class="container" style="text-align:center">
          <h2>Free to download. Free to use.</h2>
          <p>Create a GopalCycles account and download GopalDesk for your platform.</p>
          <div class="cta-actions">
            <a class="button light" href="/download/">Download GopalDesk</a>
            <a class="button outline-light" href="/auth/signup.html">Create Account</a>
          </div>
        </div>
      </section>

    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html, body { margin: 0; width: 100%; overflow-x: hidden; }
  body { font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif; color: #111827; background: #f8fafc; line-height: 1.6; }
  .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
  h1 { font-size: 50px; line-height: 1.06; letter-spacing: -0.05em; margin: 0 0 20px; }
  h2 { font-size: 32px; line-height: 1.15; letter-spacing: -0.03em; margin: 0 0 16px; }
  h3 { margin-top: 0; }
  .eyebrow { color: #2563eb; font-weight: 800; margin: 0 0 14px; }
  .eyebrow-sm { color: #2563eb; font-weight: 700; font-size: 13px; letter-spacing: 0.05em; text-transform: uppercase; margin: 0 0 10px; }
  .section-sub { color: #64748b; margin: -8px 0 28px; }
  .hero { padding: 88px 0 76px; background: #f8fafc; }
  .hero .sub { font-size: 19px; color: #334155; max-width: 720px; margin: 0 0 30px; }
  .actions { display: flex; gap: 14px; flex-wrap: wrap; }
  .button { display: inline-block; padding: 13px 20px; border-radius: 10px; font-weight: 700; text-decoration: none; font-size: 15px; }
  .primary { background: #111827; color: white; }
  .secondary { background: white; color: #111827; border: 1px solid #d1d5db; }
  .light { background: white; color: #111827; }
  .outline-light { background: transparent; color: white; border: 1px solid rgba(255,255,255,0.4); }

  /* PLATFORMS */
  .platforms-strip { background: #1e293b; padding: 28px 0; }
  .platforms-label { color: #64748b; font-size: 13px; font-weight: 600; text-transform: uppercase; letter-spacing: 0.06em; margin: 0 0 16px; }
  .platforms { display: flex; gap: 32px; flex-wrap: wrap; }
  .platform { display: flex; align-items: center; gap: 10px; }
  .platform-icon { font-size: 20px; }
  .platform strong { color: white; display: block; font-size: 14px; }
  .platform span { color: #64748b; font-size: 12px; }

  /* STEPS */
  .section { padding: 72px 0; }
  .alt { background: rgba(255,255,255,0.85); }
  .steps-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 28px; margin-top: 28px; }
  .step { display: flex; flex-direction: column; }
  .step-num { width: 40px; height: 40px; border-radius: 12px; background: #2563eb; color: white; font-weight: 900; font-size: 18px; display: flex; align-items: center; justify-content: center; margin-bottom: 14px; }
  .step p { color: #64748b; font-size: 15px; margin: 0; }
  .step a { color: #2563eb; }

  /* GRID */
  .grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 22px; margin-top: 8px; }
  .card { background: white; border: 1px solid #e5e7eb; border-radius: 16px; padding: 24px; box-shadow: 0 4px 16px rgba(15,23,42,0.05); }
  .card code { font-size: 13px; background: #f1f5f9; padding: 2px 6px; border-radius: 4px; }

  /* TWO COL */
  .two-col { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 48px; align-items: center; }
  .two-col.reverse { grid-template-columns: 0.8fr 1.2fr; }
  .panel { background: white; border: 1px solid #e5e7eb; border-radius: 16px; padding: 24px; box-shadow: 0 4px 16px rgba(15,23,42,0.05); }
  .panel ul { padding-left: 20px; margin: 0 0 16px; }
  .panel li { margin-bottom: 10px; font-size: 15px; }
  .panel-link { color: #2563eb; font-weight: 600; text-decoration: none; font-size: 14px; }
  .code-block { background: #0f172a; border-radius: 8px; padding: 12px 14px; margin: 16px 0 6px; display: flex; align-items: center; gap: 8px; overflow-x: auto; }
  .recv-tag { background: #22c55e; color: #0f172a; font-size: 10px; font-weight: 800; padding: 2px 6px; border-radius: 4px; flex-shrink: 0; }
  .code-block code { color: #86efac; font-size: 12px; white-space: nowrap; }
  .code-note { font-size: 12px; color: #94a3b8; margin: 0; }

  /* PROTOCOL NOTE */
  .protocol-note-box { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 16px; padding: 28px 32px; display: flex; justify-content: space-between; align-items: center; gap: 24px; flex-wrap: wrap; }
  .protocol-note-box h3 { margin: 0 0 8px; font-size: 18px; }
  .protocol-note-box p { margin: 0; color: #374151; font-size: 15px; }
  .protocol-note-box a { color: #2563eb; }

  /* CTA */
  .cta-section { background: #0f172a; color: white; padding: 72px 0; }
  .cta-section h2 { color: white; }
  .cta-section p { color: #94a3b8; max-width: 500px; margin: 0 auto 28px; }
  .cta-actions { display: flex; justify-content: center; gap: 14px; flex-wrap: wrap; }

  @media (max-width: 900px) {
    h1 { font-size: 36px; }
    .steps-grid, .grid, .two-col, .two-col.reverse { grid-template-columns: 1fr; }
    .platforms { gap: 20px; }
  }
  @media (max-width: 600px) {
    h1 { font-size: 28px; }
    .platforms { flex-direction: column; gap: 12px; }
  }
</style>
