---
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Contact GopalCycles for fleet setup help, GopalDesk onboarding, or questions about GPS tracking for your rental equipment."
    />
    <title>Contact GopalCycles | Fleet Setup &amp; Support</title>
    <link rel="icon" type="image/png" href="/assets/Gopallogo.png" />

    <!-- Brevo (formerly Sendinblue) JS SDK -->
    <!-- Replace YOUR_CLIENT_KEY with your actual Brevo client key from your account -->
    <script>
      window.sib = {
        equeue: [],
        client_key: "YOUR_BREVO_CLIENT_KEY"
      };
      window.sendinblue = {};
      for (var j = ['track', 'identify', 'trackLink', 'page'], i = 0; i < j.length; i++) {
        (function(k) {
          window.sendinblue[k] = function() {
            var arg = Array.prototype.slice.call(arguments);
            (window.sib[k] || function() {
              var t = {}; t[k] = arg; window.sib.equeue.push(t);
            })(arg[0], arg[1], arg[2]);
          };
        })(j[i]);
      }
      var n = document.createElement("script"), i = document.getElementsByTagName("script")[0];
      n.type = "text/javascript"; n.id = "sendinblue-js"; n.async = !0;
      n.src = "https://sibautomation.com/sa.js?key=" + window.sib.client_key;
      i.parentNode.insertBefore(n, i);
      window.sendinblue.page();
    </script>
  </head>
  <body>
    <Header />

    <main>
      <section class="hero">
        <div class="container">
          <p class="eyebrow">Contact</p>
          <h1>Let's get your fleet connected.</h1>
          <p class="sub">
            Tell us about your equipment and we'll suggest a practical GopalDesk setup —
            GPS tracking, QR workflows, smart locks, and dashboard access.
          </p>
        </div>
      </section>

      <section class="section">
        <div class="container contact-layout">

          <!-- Contact / Setup Call Form -->
          <!-- This uses Brevo's embed form. Replace with your actual Brevo form embed code. -->
          <!-- To get this: Brevo dashboard → Email Marketing → Forms → Create a subscription form -->
          <div class="form-col">
            <h2>Book a free setup call</h2>
            <p class="form-intro">
              30 minutes. We'll look at your fleet, hardware, and goals and give you a clear
              setup recommendation — no commitment required.
            </p>

            <!-- BREVO FORM EMBED -->
            <!-- Replace the content of this div with your actual Brevo embedded form code -->
            <!-- From: Brevo → Contacts → Forms → your form → Embed code -->
            <div id="brevo-contact-form" class="brevo-form-wrapper">
              <!-- Paste your Brevo form embed script/HTML here -->
              <!-- Example placeholder — replace entirely with Brevo embed: -->
              <form id="contact-form" novalidate>
                <div class="field-group">
                  <label for="contact-name">Your name</label>
                  <input type="text" id="contact-name" name="FIRSTNAME" placeholder="Alex Smith" required />
                </div>
                <div class="field-group">
                  <label for="contact-email">Email address</label>
                  <input type="email" id="contact-email" name="EMAIL" placeholder="you@example.com" required />
                </div>
                <div class="field-group">
                  <label for="contact-fleet">What equipment do you operate?</label>
                  <input type="text" id="contact-fleet" name="FLEET" placeholder="e.g. 15 e-bikes, 10 scooters (Omni)" />
                </div>
                <div class="field-group">
                  <label for="contact-message">What do you need help with?</label>
                  <textarea id="contact-message" name="MESSAGE" rows="4" placeholder="e.g. Need GPS tracking + QR rentals for a resort fleet of 20 e-bikes"></textarea>
                </div>
                <div class="field-group checkbox-group">
                  <label class="checkbox-label">
                    <input type="checkbox" id="contact-subscribe" name="OPT_IN" value="1" checked />
                    <span>Also subscribe me to GopalCycles fleet tips &amp; updates</span>
                  </label>
                </div>
                <button type="submit" class="submit-btn" id="submit-btn">Send Message</button>
                <p class="form-note" id="form-status"></p>
              </form>
            </div>
          </div>

          <div class="info-col">
            <div class="info-card">
              <h3>What happens next</h3>
              <ol class="steps">
                <li><strong>We review your fleet details</strong> and suggest a GopalDesk configuration that fits your hardware.</li>
                <li><strong>You book a 30-min call</strong> (or we reply by email — your choice) to walk through setup.</li>
                <li><strong>We help you go live</strong> with Traccar, GopalDesk, and your device integrations.</li>
              </ol>
            </div>

            <div class="info-card">
              <h3>Common questions</h3>
              <dl>
                <dt>Do I need to buy hardware?</dt>
                <dd>If your equipment already has a GPS/IoT module (Omni, Segway, Teltonika, etc.) you likely don't. We'll check.</dd>
                <dt>Is GopalDesk really free?</dt>
                <dd>Yes — for fleets up to 25 devices. You self-host the Traccar backend (Oracle Cloud Free Tier works).</dd>
                <dt>How long does setup take?</dt>
                <dd>Most operators are live within 1–2 days after the setup call, depending on hardware.</dd>
              </dl>
            </div>

            <div class="info-card email-card">
              <p>Prefer email?</p>
              <a href="mailto:hello@gopalcycles.com" class="email-link">hello@gopalcycles.com</a>
            </div>
          </div>

        </div>
      </section>

      <!-- Newsletter signup strip — uses Brevo list -->
      <section class="newsletter-strip">
        <div class="container newsletter-inner">
          <div>
            <h2>Fleet tips &amp; updates from GopalCycles</h2>
            <p>Practical guides on GPS tracking, rental IoT, and GopalDesk — direct to your inbox.</p>
          </div>
          <!-- BREVO NEWSLETTER FORM -->
          <!-- Replace with your Brevo newsletter form embed, or wire to Brevo API via fetch() -->
          <!-- Brevo list subscribe endpoint: POST https://api.brevo.com/v3/contacts -->
          <form id="newsletter-form" class="newsletter-form">
            <input type="email" id="nl-email" name="email" placeholder="Your email address" required />
            <button type="submit">Subscribe</button>
            <p class="nl-status" id="nl-status"></p>
          </form>
        </div>
      </section>
    </main>

    <Footer />

    <script>
      // ===========================
      // Contact form → Brevo API
      // ===========================
      // Wire this to your Cloudflare Worker that proxies to Brevo API,
      // so your API key never appears in frontend code.
      // Worker endpoint: https://your-worker.workers.dev/brevo-contact
      //
      // For now, replace WORKER_URL with your actual Cloudflare Worker URL.
      const WORKER_URL = 'https://YOUR_WORKER.workers.dev';

      document.getElementById('contact-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submit-btn');
        const status = document.getElementById('form-status');
        btn.disabled = true;
        btn.textContent = 'Sending…';

        const data = {
          name: document.getElementById('contact-name').value,
          email: document.getElementById('contact-email').value,
          fleet: document.getElementById('contact-fleet').value,
          message: document.getElementById('contact-message').value,
          subscribe: document.getElementById('contact-subscribe').checked,
        };

        try {
          // Option A: POST to your Cloudflare Worker (recommended)
          // const res = await fetch(`${WORKER_URL}/contact`, {
          //   method: 'POST',
          //   headers: { 'Content-Type': 'application/json' },
          //   body: JSON.stringify(data),
          // });

          // Option B: Direct Brevo transactional email (only if key is safe in Worker)
          // Use Brevo's "Send a transactional email" API via your Worker

          // Temporary: simulate success for testing
          await new Promise(r => setTimeout(r, 800));
          status.textContent = '✓ Message sent! We\'ll be in touch within 1 business day.';
          status.className = 'form-note success';
          e.target.reset();
        } catch (err) {
          status.textContent = 'Something went wrong — please email hello@gopalcycles.com directly.';
          status.className = 'form-note error';
        } finally {
          btn.disabled = false;
          btn.textContent = 'Send Message';
        }
      });

      // ===========================
      // Newsletter form → Brevo API
      // ===========================
      document.getElementById('newsletter-form')?.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = document.getElementById('nl-email').value;
        const status = document.getElementById('nl-status');

        try {
          // Replace with POST to your Worker → Brevo contacts API
          // const res = await fetch(`${WORKER_URL}/subscribe`, {
          //   method: 'POST',
          //   headers: { 'Content-Type': 'application/json' },
          //   body: JSON.stringify({ email }),
          // });

          await new Promise(r => setTimeout(r, 600));
          status.textContent = '✓ Subscribed! Check your inbox for a confirmation.';
          e.target.reset();
        } catch {
          status.textContent = 'Failed — please try again.';
        }
      });
    </script>
  </body>
</html>

<style is:global>
  html, body { margin: 0; width: 100%; overflow-x: hidden; }
  body {
    font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif;
    color: #111827; background: #f8fafc; line-height: 1.6;
  }
  .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
  h1 { font-size: 48px; line-height: 1.08; letter-spacing: -0.05em; margin: 0 0 18px; }
  h2 { font-size: 28px; line-height: 1.2; letter-spacing: -0.03em; margin: 0 0 14px; }
  h3 { margin-top: 0; font-size: 18px; }
  .eyebrow { color: #2563eb; font-weight: 800; margin: 0 0 12px; }
  .hero { padding: 72px 0 60px; }
  .hero .sub { font-size: 19px; color: #334155; max-width: 660px; margin: 0; }
  .section { padding: 60px 0 72px; }
  .contact-layout { display: grid; grid-template-columns: 1.1fr 0.9fr; gap: 56px; align-items: start; }
  .form-intro { color: #64748b; margin-bottom: 28px; }
  .field-group { margin-bottom: 18px; }
  .field-group label { display: block; font-size: 13px; font-weight: 600; margin-bottom: 6px; color: #374151; }
  .field-group input,
  .field-group textarea {
    width: 100%; box-sizing: border-box;
    padding: 11px 14px; border: 1px solid #d1d5db; border-radius: 8px;
    font-size: 15px; color: #111827; background: white; outline: none;
    font-family: inherit;
  }
  .field-group input:focus,
  .field-group textarea:focus { border-color: #2563eb; box-shadow: 0 0 0 3px rgba(37,99,235,0.1); }
  .field-group textarea { resize: vertical; }
  .checkbox-group { display: flex; align-items: flex-start; }
  .checkbox-label { display: flex; gap: 10px; align-items: flex-start; cursor: pointer; font-size: 14px; color: #4b5563; }
  .checkbox-label input { width: auto; margin-top: 2px; }
  .submit-btn {
    width: 100%; padding: 14px; background: #111827; color: white;
    border: none; border-radius: 10px; font-size: 16px; font-weight: 700;
    cursor: pointer; margin-top: 6px;
  }
  .submit-btn:hover { background: #1e293b; }
  .submit-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .form-note { font-size: 14px; margin-top: 10px; }
  .form-note.success { color: #16a34a; }
  .form-note.error { color: #dc2626; }
  .info-col { display: flex; flex-direction: column; gap: 20px; }
  .info-card { background: white; border: 1px solid #e5e7eb; border-radius: 16px; padding: 24px; box-shadow: 0 4px 16px rgba(15,23,42,0.05); }
  .steps { padding-left: 20px; margin: 0; }
  .steps li { margin-bottom: 14px; font-size: 15px; }
  dl dt { font-weight: 700; margin-bottom: 4px; margin-top: 16px; }
  dl dt:first-child { margin-top: 0; }
  dl dd { margin: 0 0 4px; color: #64748b; font-size: 14px; }
  .email-card { text-align: center; }
  .email-card p { margin: 0 0 8px; color: #64748b; font-size: 14px; }
  .email-link { font-size: 18px; font-weight: 700; color: #2563eb; text-decoration: none; }
  .newsletter-strip { background: #1e293b; padding: 56px 0; }
  .newsletter-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 48px; align-items: center; }
  .newsletter-strip h2 { color: white; margin-bottom: 8px; }
  .newsletter-strip p { color: #94a3b8; margin: 0; }
  .newsletter-form { display: flex; flex-direction: column; gap: 10px; }
  .newsletter-form input {
    padding: 12px 16px; border: 1px solid rgba(255,255,255,0.2);
    border-radius: 8px; background: rgba(255,255,255,0.08);
    color: white; font-size: 15px; outline: none; font-family: inherit;
  }
  .newsletter-form input::placeholder { color: rgba(255,255,255,0.45); }
  .newsletter-form input:focus { border-color: #2563eb; }
  .newsletter-form button {
    padding: 13px; background: #2563eb; color: white;
    border: none; border-radius: 8px; font-size: 15px; font-weight: 700; cursor: pointer;
  }
  .newsletter-form button:hover { background: #1d4ed8; }
  .nl-status { color: #86efac; font-size: 14px; margin: 0; }
  @media (max-width: 900px) {
    .contact-layout, .newsletter-inner { grid-template-columns: 1fr; gap: 36px; }
    h1 { font-size: 36px; }
  }
</style>
