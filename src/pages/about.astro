---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="GopalCycles builds IoT-connected rental fleet tools for operators managing e-bikes, scooters, and outdoor equipment. Based in Toronto, Canada."
    />
    <title>About GopalCycles | Connected Rental Fleet Tools</title>
    <link rel="icon" type="image/png" href="/assets/Gopallogo.png" />
  </head>
  <body>
    <Header />
    <main>
      <section class="hero">
        <div class="container">
          <p class="eyebrow">About</p>
          <h1>Built by people who have connected rental fleets for a living.</h1>
          <p class="sub">
            GopalCycles comes from years of hands-on work in IoT, telematics, and connected
            mobility — from Segway-Ninebot hardware in Beijing to scooter fleet platforms in North America.
          </p>
        </div>
      </section>

      <section class="section">
        <div class="container two-col">
          <div>
            <h2>Why GopalCycles exists</h2>
            <p>
              Most fleet management software is built for large operators with large budgets.
              Small and mid-size rental operators — resorts, bike shares, campus fleets, tour operators —
              get priced out of good tools or pushed into platforms with per-device fees that don't
              make sense at their scale.
            </p>
            <p>
              GopalCycles is different. GopalDesk is free for small fleets. You self-host the backend.
              You own your data. We help you get set up and keep things running.
            </p>
            <p>
              We are based in Toronto, Canada and work with rental operators across North America.
            </p>
          </div>
          <div class="panel">
            <h3>What we bring</h3>
            <ul>
              <li>8+ years in IoT and telematics hardware</li>
              <li>CAN bus, MQTT, Modbus, TCP/IP protocol work</li>
              <li>Traccar self-hosting and configuration</li>
              <li>Omni, Segway-Ninebot, Teltonika integrations</li>
              <li>Cloudflare-first security architecture</li>
              <li>Supabase auth and RLS for access control</li>
            </ul>
          </div>
        </div>
      </section>

      <section class="cta-section">
        <div class="container" style="text-align:center">
          <h2>Questions? We are easy to reach.</h2>
          <p>Email us at <a href="mailto:hello@gopalcycles.com" style="color:#93c5fd">hello@gopalcycles.com</a> or book a setup call.</p>
          <a class="button light" href="/contact/">Contact GopalCycles</a>
        </div>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style is:global>
  html, body { margin: 0; width: 100%; overflow-x: hidden; }
  body { font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", Arial, sans-serif; color: #111827; background: #f8fafc; line-height: 1.6; }
  .container { max-width: 1120px; margin: 0 auto; padding: 0 24px; }
  h1 { font-size: 48px; line-height: 1.08; letter-spacing: -0.05em; margin: 0 0 18px; }
  h2 { font-size: 32px; line-height: 1.15; letter-spacing: -0.03em; margin: 0 0 16px; }
  h3 { margin-top: 0; }
  .eyebrow { color: #2563eb; font-weight: 800; margin: 0 0 12px; }
  .hero { padding: 80px 0 60px; }
  .hero .sub { font-size: 19px; color: #334155; max-width: 700px; margin: 0; }
  .section { padding: 72px 0; }
  .two-col { display: grid; grid-template-columns: 1.2fr 0.8fr; gap: 48px; align-items: start; }
  .panel { background: white; border: 1px solid #e5e7eb; border-radius: 16px; padding: 24px; box-shadow: 0 4px 16px rgba(15,23,42,0.05); }
  .panel ul { padding-left: 20px; margin: 0; }
  .panel li { margin-bottom: 10px; font-size: 15px; }
  .cta-section { background: #111827; color: white; padding: 72px 0; }
  .cta-section h2 { color: white; }
  .cta-section p { color: #94a3b8; margin-bottom: 28px; }
  .button { display: inline-block; padding: 13px 20px; border-radius: 10px; font-weight: 700; text-decoration: none; }
  .light { background: white; color: #111827; }
  @media (max-width: 800px) { h1 { font-size: 34px; } .two-col { grid-template-columns: 1fr; } }
</style>
